{
  "name": "kolscan-base",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",

    "_comment_indexer": "=== PROGRAMA 1: INDEXER (blockchain → MySQL) ===",
    "indexer": "node dist/indexer-main.js",
    "indexer:dev": "nodemon --exec ts-node src/indexer-main.ts",
    "indexer:api-only": "INDEXER_ENABLED=false nodemon --exec ts-node src/indexer-main.ts",

    "_comment_analyzer": "=== PROGRAMA 2: ANALYZER (métricas e follow score) ===",
    "analyzer": "node dist/analyzer-main.js",
    "analyzer:dev": "nodemon --exec ts-node src/analyzer-main.ts",

    "_comment_legacy": "=== LEGADO (mantido para compatibilidade) ===",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:api-only": "INDEXER_ENABLED=false nodemon --exec ts-node src/index.ts",

    "_comment_tools": "=== FERRAMENTAS ===",
    "typecheck": "tsc --noEmit",
    "db:migrate": "ts-node -e \"require('./src/database/migrations').runMigrations().then(() => process.exit(0)).catch((e: unknown) => { console.error(e); process.exit(1); })\"",
    "recalculate-holding": "ts-node src/scripts/recalculate-holding.ts",
    "recalculate-pnl": "ts-node src/scripts/recalculate-pnl.ts",
    "recalculate-pnl-amostra": "ts-node src/scripts/recalculate-pnl-amostra.ts",
    "recalculate-all": "ts-node src/scripts/recalculate-all.ts",
    "top-traders": "ts-node src/scripts/top-traders.ts",
    "wallet-detail": "ts-node src/scripts/wallet-detail.ts --",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrozgrin/kolscan-base.git"
  },
  "keywords": [
    "blockchain",
    "base",
    "kol",
    "defi",
    "trading",
    "indexer",
    "leaderboard",
    "on-chain"
  ],
  "author": "mrozgrin",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/mrozgrin/kolscan-base/issues"
  },
  "homepage": "https://github.com/mrozgrin/kolscan-base#readme",
  "description": "Backend Node.js para rastreamento de KOLs (Key Opinion Leaders) na blockchain Base",
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bull": "^4.16.5",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "mysql2": "^3.18.2",
    "winston": "^3.19.0"
  }
}
