# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores

#---------------------------------------
# Configurações do Servidor
#---------------------------------------
# Porta da API
PORT=3000
# Ambiente (development, production)
NODE_ENV=development
# Origem permitida para CORS (ex: http://localhost:3001)
CORS_ORIGIN=*

#---------------------------------------
# Configurações do Banco de Dados (PostgreSQL)
#---------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kolscan_base
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

#---------------------------------------
# Configurações do Redis (para cache e filas)
#---------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

#---------------------------------------
# Configurações da Blockchain (Base)
#---------------------------------------
# URL do seu RPC Provider (ex: Alchemy, QuickNode)
BASE_RPC_URL=
# URL de fallback (opcional)
BASE_RPC_URL_FALLBACK=https://base.llamarpc.com
# Bloco inicial para indexação (0 para começar do início)
START_BLOCK=0
# Número de blocos a processar por batch
BATCH_SIZE=50
# Intervalo de polling para novos blocos (em ms)
POLLING_INTERVAL=2000

#---------------------------------------
# Configurações do Indexador
#---------------------------------------
# Habilitar/desabilitar o indexador (true/false)
INDEXER_ENABLED=true
# Intervalo para atualizar métricas dos KOLs (em ms)
METRICS_UPDATE_INTERVAL=300000
# Número mínimo de trades para um endereço ser considerado KOL
MIN_TRADES_FOR_KOL=5
# Tamanho do leaderboard
LEADERBOARD_SIZE=100

#---------------------------------------
# Configurações de Cache
#---------------------------------------
# TTL do cache do leaderboard (em segundos)
LEADERBOARD_CACHE_TTL=60
# TTL do cache dos detalhes de um KOL (em segundos)
KOL_DETAILS_CACHE_TTL=120
# TTL do cache de preços de tokens (em segundos)
TOKEN_PRICE_CACHE_TTL=30

#---------------------------------------
# Configurações de Logging
#---------------------------------------
# Nível de log (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info
# Formato do log (json ou simple)
LOG_FORMAT=simple
# Arquivo de log (opcional)
# LOG_FILE=app.log
